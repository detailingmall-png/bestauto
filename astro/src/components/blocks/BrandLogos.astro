---
/**
 * BrandLogos — PPF film brands section.
 * Shows brand cards in a horizontal grid with gold accent names.
 */

interface BrandCard {
  name: string;
  description: string;
}

interface Props {
  sectionTitle: string;
  subtitle?: string;
  brands: BrandCard[];
}

const { sectionTitle, subtitle, brands } = Astro.props;
---

<section class="section-spacing">
  <div class="container-ba">
    <div class="text-center mb-3 lg:mb-4">
      <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-balance mb-2">
        {sectionTitle}
      </h2>
      {subtitle && (
        <p class="text-md lg:text-xl text-gray-400">{subtitle}</p>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 max-w-5xl mx-auto">
      {brands.map((brand, index) => (
        <div
          data-reveal={String(Math.min(index, 5))}
          class="rounded-xl border border-gray-800 p-3 hover:border-gold-accent/20 transition-colors duration-300"
        >
          <h3 class="text-base lg:text-xl font-semibold text-gold-accent">
            {brand.name}
          </h3>
          <p class="text-xs lg:text-sm text-gray-400 leading-relaxed mt-1">
            {brand.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
