---
/**
 * ProcessSteps — t508-style numbered vertical list.
 * Gold numbered circles on the left, title + description on the right.
 */

interface Step {
  title: string;
  description: string;
}

interface Props {
  sectionTitle?: string;
  steps: Step[];
}

const { sectionTitle, steps } = Astro.props;
---

<section class="section-spacing bg-gray-900/30">
  <div class="container-ba">
    {sectionTitle && (
      <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-center text-balance mb-3 lg:mb-4">
        {sectionTitle}
      </h2>
    )}

    <div class="max-w-3xl mx-auto">
      {steps.map((step, index) => (
        <div
          data-reveal={String(Math.min(index, 5))}
          class="flex items-start gap-3 py-2"
        >
          <div class="w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center shrink-0 mt-0.5">
            <span class="text-sm font-bold text-black-primary">{index + 1}</span>
          </div>
          <div>
            <h3 class="text-xl lg:text-2xl font-semibold text-white-primary mb-0.5">
              {step.title}
            </h3>
            <p class="text-base lg:text-md text-gray-400 leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
