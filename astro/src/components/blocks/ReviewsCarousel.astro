---
/**
 * ReviewsCarousel — Google Reviews horizontal scroll section.
 * Pure CSS snap-scroll carousel, no JavaScript required.
 */

interface Review {
  authorName: string;
  authorPhotoUrl?: string;
  rating: number;
  relativeTime: string;
  text: string;
}

interface Props {
  sectionTitle: string;
  overallRating: number;
  totalReviews: number;
  reviews: Review[];
  mapsUrl?: string;
  lang: 'ka' | 'ru' | 'en';
}

const { sectionTitle, overallRating, totalReviews, reviews, mapsUrl, lang } = Astro.props;

const ctaLabels: Record<string, string> = {
  ru: 'Смотреть все отзывы на Google',
  en: 'See all reviews on Google',
  ka: 'ყველა მიმოხილვის ნახვა Google-ზე',
};
const ctaText = ctaLabels[lang] ?? ctaLabels.ru;

function getInitials(name: string): string {
  return name
    .split(' ')
    .slice(0, 2)
    .map((w) => w.charAt(0).toUpperCase())
    .join('');
}

function renderStars(count: number): string {
  const filled = Math.round(Math.min(count, 5));
  return '★'.repeat(filled) + '☆'.repeat(5 - filled);
}
---

<section class="section-spacing">
  <div class="container-ba">
    {/* ── Header ── */}
    <div class="text-center mb-3 lg:mb-4">
      <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-balance mb-2">
        {sectionTitle}
      </h2>

      {/* Google wordmark */}
      <p class="text-xl lg:text-3xl font-semibold mb-1" aria-label="Google Reviews">
        <span class="text-[#4285F4]">G</span><span class="text-[#EA4335]">o</span><span class="text-[#FBBC05]">o</span><span class="text-[#4285F4]">g</span><span class="text-[#34A853]">l</span><span class="text-[#EA4335]">e</span>
        <span class="text-white-primary ml-1">
          {lang === 'ru' ? 'Отзывы' : lang === 'ka' ? 'მიმოხილვები' : 'Reviews'}
        </span>
      </p>

      {/* Rating summary */}
      <p class="text-2xl text-white-primary">
        <span class="font-bold">{overallRating}</span>
        <span class="text-gold-accent ml-1">{renderStars(Math.round(overallRating))}</span>
        <span class="text-lg text-gray-400 ml-1">({totalReviews})</span>
      </p>
    </div>

    {/* ── Carousel ── */}
    <div class="reviews-scroll flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-4 px-4 lg:-mx-0 lg:px-0">
      {reviews.map((review, index) => (
        <article
          data-reveal={String(Math.min(index, 5))}
          class="min-w-[280px] md:min-w-[300px] max-w-[340px] flex-shrink-0 snap-start rounded-xl border border-gray-800 p-5 flex flex-col gap-3"
        >
          {/* Author row */}
          <div class="flex items-center gap-3">
            {review.authorPhotoUrl ? (
              <img
                src={review.authorPhotoUrl}
                alt=""
                aria-hidden="true"
                width="40"
                height="40"
                loading="lazy"
                decoding="async"
                class="w-10 h-10 rounded-full object-cover flex-shrink-0"
              />
            ) : (
              <div class="w-10 h-10 rounded-full bg-gold-accent/15 flex items-center justify-center flex-shrink-0">
                <span class="text-sm font-semibold text-gold-accent">{getInitials(review.authorName)}</span>
              </div>
            )}
            <div class="min-w-0">
              <p class="text-base font-semibold text-white-primary truncate">{review.authorName}</p>
              <p class="text-xs text-gray-400">
                {review.relativeTime}
                {' '}
                <span class="review-google-label">
                  {lang === 'ru' ? 'на ' : lang === 'ka' ? '' : 'on '}
                  <span class="text-[#4285F4]">G</span><span class="text-[#EA4335]">o</span><span class="text-[#FBBC05]">o</span><span class="text-[#4285F4]">g</span><span class="text-[#34A853]">l</span><span class="text-[#EA4335]">e</span>
                </span>
              </p>
            </div>
          </div>

          {/* Stars */}
          <p class="text-gold-accent text-lg leading-none" aria-label={`${review.rating} out of 5 stars`}>
            {renderStars(review.rating)}
          </p>

          {/* Review text */}
          <p class="text-sm text-gray-300 leading-relaxed line-clamp-4 flex-1">
            {review.text}
          </p>
        </article>
      ))}
    </div>

    {/* ── CTA link ── */}
    {mapsUrl && (
      <div class="text-center mt-8">
        <a
          href={mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 text-md text-gold-accent hover:text-gold-light transition-colors duration-200"
        >
          {ctaText}
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    )}
  </div>
</section>

<style>
  /* Hide scrollbar but keep scroll functionality */
  .reviews-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .reviews-scroll::-webkit-scrollbar {
    display: none;
  }

  /* line-clamp fallback for older browsers */
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
