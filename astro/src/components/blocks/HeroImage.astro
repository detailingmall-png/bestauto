---
/**
 * HeroImage — full-width hero with background image, dark overlay, centered text.
 * Matches original Tilda t396 Zero Block design.
 */

interface Props {
  title: string;
  subtitle: string;
  ctaText: string;
  ctaHref?: string;
  /** URL to background image */
  bgImage: string;
}

const {
  title,
  subtitle,
  ctaText,
  ctaHref = '#contacts',
  bgImage,
} = Astro.props;
---

<section
  class="relative min-h-[60vh] md:min-h-[70vh] flex items-center justify-center overflow-hidden"
>
  {/* Background image */}
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${bgImage}')`}
    aria-hidden="true"
  ></div>

  {/* Dark overlay */}
  <div class="absolute inset-0 bg-black/60" aria-hidden="true"></div>

  {/* Content — centered */}
  <div class="relative z-10 flex flex-col items-center text-center px-2 py-4 md:py-8">
    <h1 class="text-5xl md:text-7xl lg:text-9xl font-bold text-white-primary text-balance leading-tight">
      {title}
    </h1>

    <p class="mt-2 md:mt-3 text-md md:text-xl text-gray-300 leading-relaxed max-w-3xl mx-auto">
      {subtitle}
    </p>

    <a
      href={ctaHref}
      class="mt-4 md:mt-5 inline-flex items-center justify-center bg-gold-accent text-black-primary font-semibold rounded-full px-5 py-2 text-lg hover:bg-gold-hover transition-colors duration-300 no-underline min-h-[48px]"
    >
      {ctaText}
    </a>
  </div>
</section>
