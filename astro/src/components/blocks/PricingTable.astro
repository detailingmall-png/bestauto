---
/**
 * PricingTable — minimal pricing rows with dotted line fill.
 * Matches original Tilda t585 design: name ... price.
 */

interface PriceItem {
  name: string;
  price: string;
  isPromo?: boolean;
}

interface Props {
  sectionTitle?: string;
  subtitle?: string;
  items: PriceItem[];
  currency?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  sectionTitle,
  subtitle,
  items,
  currency = 'GEL',
  ctaText,
  ctaHref = '#contacts',
} = Astro.props;
---

<section class="section-spacing" id="prices">
  <div class="container-ba">
    {sectionTitle && (
      <h2 class="text-4xl lg:text-6xl font-bold text-white-primary text-center text-balance mb-2">
        {sectionTitle}
      </h2>
    )}

    {subtitle && (
      <p class="text-gray-400 text-center text-md lg:text-xl mb-3 lg:mb-4 max-w-2xl mx-auto">
        {subtitle}
      </p>
    )}

    <div class="max-w-3xl mx-auto" data-reveal>
      {items.map((item, index) => (
        <div
          class={`flex items-baseline py-3 ${
            index !== items.length - 1 ? 'border-b border-gray-800/50' : ''
          }`}
        >
          <span
            class={`text-lg lg:text-2xl ${
              item.isPromo
                ? 'text-gold-accent font-semibold'
                : 'text-white-primary'
            }`}
          >
            {item.name}
          </span>

          {/* Dotted line fill */}
          <span
            class="flex-1 border-b border-dotted border-gray-700 mx-3 self-end mb-1"
            aria-hidden="true"
          ></span>

          <span class="text-lg lg:text-2xl font-semibold text-white-primary whitespace-nowrap">
            {item.price} {currency}
          </span>
        </div>
      ))}
    </div>

    {ctaText && (
      <div class="text-center mt-10 lg:mt-16">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center bg-gold-accent text-black-primary font-semibold rounded-full px-10 py-4 text-lg hover:bg-gold-hover transition-colors duration-300 no-underline"
        >
          {ctaText}
        </a>
      </div>
    )}
  </div>
</section>
