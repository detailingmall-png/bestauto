---
/**
 * RelatedServices — grid of related service cards.
 * Replaces Tilda type-692 blocks.
 */

interface ServiceCard {
  name: string;
  href: string;
}

interface Props {
  sectionTitle: string;
  services: ServiceCard[];
  lang: 'ka' | 'ru' | 'en';
}

const { sectionTitle, services, lang } = Astro.props;

const ctaLabel = lang === 'ka' ? 'გაიგეთ მეტი' : lang === 'ru' ? 'Подробнее' : 'Learn more';
---

<section class="section-spacing bg-gray-900/30">
  <div class="container-ba">
    <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-center text-balance mb-10 lg:mb-16">
      {sectionTitle}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((service, index) => (
        <a
          href={service.href}
          data-reveal={String(Math.min(index, 5))}
          class="group block p-6 rounded-xl border border-gray-800 hover:border-gold-accent/30 transition-all duration-300 hover:scale-[1.02] no-underline"
        >
          <h3 class="text-2xl font-semibold text-white-primary mb-3 group-hover:text-gold-accent transition-colors">
            {service.name}
          </h3>
          <span class="text-md text-gold-accent">
            {ctaLabel} &rarr;
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
