---
/**
 * ContactForm — studio contact cards matching original Tilda design.
 * "Choose nearest studio" heading with italic accent, 2 cards side by side.
 * Each card: studio name, address, phone, hours, action buttons row, gold CTA.
 */

import type { Studio } from '../../lib/sanity';

interface Props {
  lang: 'ka' | 'ru' | 'en';
  sectionTitle?: string;
  studios: Studio[];
  instagramUrl?: string;
}

const { lang, sectionTitle, studios, instagramUrl } = Astro.props;

const labels = {
  ka: {
    defaultTitle: 'აირჩიეთ უახლოესი სტუდია',
    defaultTitleAccent: 'უახლოესი',
    hours: 'სამუშაო საათები',
    whatsapp: 'WHATSAPP',
    onMap: 'რუკაზე',
    instagram: 'INSTAGRAM',
    cta: 'ჩაეწერეთ ამ სტუდიაში',
  },
  ru: {
    defaultTitle: 'Выберите ближайшую студию',
    defaultTitleAccent: 'ближайшую',
    hours: 'Часы работы',
    whatsapp: 'WHATSAPP',
    onMap: 'НА КАРТЕ',
    instagram: 'INSTAGRAM',
    cta: 'ЗАПИСАТЬСЯ В ЭТУ СТУДИЮ',
  },
  en: {
    defaultTitle: 'Choose the nearest studio',
    defaultTitleAccent: 'nearest',
    hours: 'Working hours',
    whatsapp: 'WHATSAPP',
    onMap: 'ON MAP',
    instagram: 'INSTAGRAM',
    cta: 'BOOK THIS STUDIO',
  },
};

const t = labels[lang];
const title = sectionTitle ?? t.defaultTitle;

function studioName(studio: Studio): string {
  return lang === 'ka' ? studio.nameKa : lang === 'ru' ? studio.nameRu : studio.nameEn;
}

function studioAddress(studio: Studio): string {
  return lang === 'ka' ? studio.addressKa : lang === 'ru' ? studio.addressRu : studio.addressEn;
}

function studioHours(studio: Studio): string {
  return lang === 'ka' ? studio.hoursKa : lang === 'ru' ? studio.hoursRu : studio.hoursEn;
}

/**
 * Render section title with italic accent word.
 * If sectionTitle is custom (passed explicitly), render as-is.
 * If using default, wrap the accent word in <em>.
 */
function renderTitle(titleText: string, accent: string): string {
  if (sectionTitle) return titleText;
  return titleText.replace(accent, `<em class="italic">${accent}</em>`);
}
---

<section class="section-spacing bg-gray-900/30" id="contacts">
  <div class="container-ba">
    <h2
      class="text-5xl lg:text-7xl font-bold text-white-primary text-center text-balance mb-3 lg:mb-4"
      set:html={renderTitle(title, t.defaultTitleAccent)}
    />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 max-w-5xl mx-auto">
      {studios.map((studio, index) => (
        <div
          data-reveal={String(Math.min(index, 5))}
          class="rounded-2xl border border-gray-800 p-6 lg:p-8 flex flex-col"
        >
          {/* Studio label */}
          <div class="flex items-center gap-2 mb-4">
            <span class="w-2 h-2 rounded-full bg-gold-accent shrink-0" aria-hidden="true" />
            <span class="text-sm tracking-wider text-gray-400 uppercase">
              {studioName(studio)}
            </span>
          </div>

          {/* Address */}
          <p class="text-lg text-white-primary mb-3">
            {studioAddress(studio)}
          </p>

          {/* Phone */}
          <a
            href={`tel:${studio.phone}`}
            class="text-2xl lg:text-3xl font-bold text-white-primary no-underline hover:text-gold-accent transition-colors mb-2"
          >
            {studio.phone}
          </a>

          {/* Hours */}
          <p class="text-sm text-gray-400 mb-6">
            {studioHours(studio)}
          </p>

          {/* Action buttons row */}
          <div class="flex flex-wrap gap-2 mb-6">
            {studio.whatsapp && (
              <a
                href={`https://wa.me/${studio.whatsapp.replace(/[^0-9]/g, '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center border border-gray-600 rounded-full px-4 py-2 text-sm text-gray-300 no-underline hover:border-gray-400 hover:text-white-primary transition-colors"
                aria-label={`${t.whatsapp} ${studioName(studio)}`}
              >
                {t.whatsapp}
              </a>
            )}
            {studio.mapsUrl && (
              <a
                href={studio.mapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 border border-gray-600 rounded-full px-4 py-2 text-sm text-gray-300 no-underline hover:border-gray-400 hover:text-white-primary transition-colors"
                aria-label={`${t.onMap} ${studioName(studio)}`}
              >
                {t.onMap} <span class="text-gold-accent">&#9733;</span> 5.0
              </a>
            )}
            {instagramUrl && (
              <a
                href={instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center border border-gray-600 rounded-full px-4 py-2 text-sm text-gray-300 no-underline hover:border-gray-400 hover:text-white-primary transition-colors"
                aria-label="Instagram"
              >
                {t.instagram}
              </a>
            )}
          </div>

          {/* Gold CTA button */}
          <a
            href={`https://wa.me/${studio.whatsapp?.replace(/[^0-9]/g, '') ?? ''}`}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto block w-full text-center bg-gold-accent text-black-primary rounded-lg py-3 font-semibold no-underline hover:bg-gold-hover transition-colors"
          >
            {t.cta} &rarr;
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
