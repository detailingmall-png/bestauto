---
/**
 * Breadcrumbs — navigation breadcrumbs for non-homepage pages.
 * Placed immediately below the header, above the hero.
 * Uses BreadcrumbList schema markup (handled by Head.astro JSON-LD).
 */

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="breadcrumbs container-ba py-1.5">
  <ol class="flex flex-wrap items-center gap-0.5 text-xs text-gray-400">
    {items.map((item, index) => (
      <li class="flex items-center gap-0.5">
        {index > 0 && (
          <span aria-hidden="true" class="text-gray-600">/</span>
        )}
        {item.href ? (
          <a
            href={item.href}
            class="hover:text-gold-accent transition-colors duration-200 no-underline"
          >
            {item.label}
          </a>
        ) : (
          <span aria-current="page" class="text-gray-300">
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  /* Override global min-height/min-width on breadcrumb links */
  .breadcrumbs a {
    min-height: auto;
    min-width: auto;
  }
</style>
