---
/**
 * TrustSection — trust/credibility points section.
 * Replaces Tilda t508 icon list for "why choose us" blocks.
 */

interface TrustItem {
  title: string;
  description?: string;
}

interface Props {
  sectionTitle: string;
  sectionSubtitle?: string;
  items: TrustItem[];
}

const { sectionTitle, sectionSubtitle, items } = Astro.props;
---

<section class="section-spacing">
  <div class="container-ba">
    <div class="text-center mb-10 lg:mb-16">
      <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-balance mb-3">
        {sectionTitle}
      </h2>
      {sectionSubtitle && (
        <p class="text-xl text-gray-400">{sectionSubtitle}</p>
      )}
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {items.map((item, index) => (
        <div data-reveal={String(Math.min(index, 5))} class="flex items-start gap-4 p-5 rounded-xl border border-gray-800 hover:border-gold-accent/20 transition-colors duration-300">
          <div class="shrink-0 w-8 h-8 rounded-full bg-gold-accent/10 flex items-center justify-center mt-0.5">
            <svg class="w-4 h-4 text-gold-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold text-white-primary mb-1">
              {item.title}
            </h3>
            {item.description && (
              <p class="text-md text-gray-400 leading-relaxed">
                {item.description}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
