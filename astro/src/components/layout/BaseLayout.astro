---
/**
 * BaseLayout: base layout for all new component-based pages.
 * Replaces TildaPageLayout.astro for migrated pages.
 */

import '../../styles/fonts.css';
import '../../styles/global.css';

interface Props {
  /** BCP-47 language tag */
  lang: 'ka' | 'ru' | 'en';
}

const { lang } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <slot name="head" />
</head>
<body>
  <!-- Skip link for accessibility -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-gold-accent focus:text-black-primary focus:px-4 focus:py-2 focus:rounded-md focus:font-semibold">
    {lang === 'ru' ? 'Перейти к содержанию' : lang === 'en' ? 'Skip to content' : 'შინაარსზე გადასვლა'}
  </a>

  <slot name="header" />

  <main id="main-content">
    <slot />
  </main>

  <slot name="footer" />

  <script src="/js/tracking.js" defer></script>
  <script>
    import '../ui/scroll-reveal.ts';
  </script>
</body>
</html>
