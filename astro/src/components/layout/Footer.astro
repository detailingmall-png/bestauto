---
/**
 * Footer — site footer with navigation and copyright.
 * Replaces Tilda t457 block.
 */

interface Props {
  lang: 'ka' | 'ru' | 'en';
}

const { lang } = Astro.props;

const prefix = lang === 'ka' ? '' : `/${lang}`;

const labels = {
  ka: {
    services: 'სერვისები',
    advantages: 'უპირატესობები',
    prices: 'ფასები',
    blog: 'ბლოგი',
  },
  ru: {
    services: 'Услуги',
    advantages: 'Преимущества',
    prices: 'Цены',
    blog: 'Блог',
  },
  en: {
    services: 'Services',
    advantages: 'Advantages',
    prices: 'Prices',
    blog: 'Blog',
  },
};

const t = labels[lang];

const footerLinks = [
  { label: t.prices, href: `${prefix}/prices/` },
  { label: t.advantages, href: '#about' },
  { label: t.services, href: `${prefix}/#service` },
  { label: t.blog, href: `${prefix}/blog/` },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-gray-800/50 py-8">
  <div class="container-ba">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href={`${prefix}/`} class="no-underline">
        <img
          src="/images/tild6165-3264-4934-b662-663336336636__noroot.png"
          alt="BESTAUTO"
          width="120"
          height="28"
          loading="lazy"
        />
      </a>

      <!-- Links -->
      <nav class="flex flex-wrap justify-center gap-6" aria-label="Footer navigation">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="text-base text-gray-400 hover:text-white-primary transition-colors duration-300 no-underline"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Copyright -->
      <p class="text-sm text-gold-accent">
        &copy; BESTAUTO 2024 - {currentYear}
      </p>
    </div>
  </div>
</footer>
