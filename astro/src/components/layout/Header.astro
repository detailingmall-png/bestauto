---
/**
 * Header — sticky navigation with desktop menu + mobile burger.
 * Replaces Tilda t228 block.
 */

import MobileNav from '../ui/MobileNav.tsx';

interface Props {
  lang: 'ka' | 'ru' | 'en';
  /** Base slug without language prefix for language switcher links */
  baseSlug?: string;
}

const { lang, baseSlug = '' } = Astro.props;

const labels = {
  ka: {
    services: 'სერვისები',
    advantages: 'უპირატესობები',
    photos: 'ფოტო',
    reviews: 'შეფასებები',
    prices: 'ფასები',
    contacts: 'კონტაქტები',
    book: 'ჩაწერა',
  },
  ru: {
    services: 'Услуги',
    advantages: 'Преимущества',
    photos: 'Фото',
    reviews: 'Отзывы',
    prices: 'Цены',
    contacts: 'Контакты',
    book: 'Записаться',
  },
  en: {
    services: 'Services',
    advantages: 'Advantages',
    photos: 'Photos',
    reviews: 'Reviews',
    prices: 'Prices',
    contacts: 'Contacts',
    book: 'Book Now',
  },
};

const t = labels[lang];
const prefix = lang === 'ka' ? '' : `/${lang}`;

const navItems = [
  { label: t.services, href: `${prefix}/#service` },
  { label: t.advantages, href: '#about' },
  { label: t.photos, href: '#photo' },
  { label: t.reviews, href: '#reviews' },
  { label: t.prices, href: `${prefix}/prices/` },
  { label: t.contacts, href: '#contacts' },
];

const langLinks = [
  { label: 'KA', href: baseSlug ? `/${baseSlug}/` : '/', active: lang === 'ka' },
  { label: 'RU', href: baseSlug ? `/ru/${baseSlug}/` : '/ru/', active: lang === 'ru' },
  { label: 'EN', href: baseSlug ? `/en/${baseSlug}/` : '/en/', active: lang === 'en' },
];
---

<header class="fixed top-0 left-0 right-0 z-30 bg-black-primary/95 backdrop-blur-sm border-b border-gray-800/50">
  <div class="container-ba flex items-center justify-between h-16 lg:h-18">
    <!-- Logo -->
    <a href={`${prefix}/`} class="flex items-center gap-2 no-underline shrink-0">
      <img
        src="/images/tild6165-3264-4934-b662-663336336636__noroot.png"
        alt="BESTAUTO"
        width="140"
        height="32"
        loading="eager"
      />
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden lg:flex items-center gap-6" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-lg text-white-primary hover:text-gold-accent transition-colors duration-300 no-underline whitespace-nowrap"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop: CTA + Lang switcher -->
    <div class="hidden lg:flex items-center gap-4">
      {/* Language switcher */}
      <div class="flex gap-2">
        {langLinks.map((l) => (
          <a
            href={l.href}
            class={`text-sm no-underline ${
              l.active ? 'text-gold-accent font-semibold' : 'text-gray-400 hover:text-white-primary'
            } transition-colors`}
          >
            {l.label}
          </a>
        ))}
      </div>

      <a
        href="#contacts"
        class="inline-flex items-center justify-center bg-gold-accent text-black-primary font-semibold rounded-full px-6 py-2.5 hover:bg-gold-hover transition-colors duration-300 no-underline text-lg"
      >
        {t.book}
      </a>
    </div>

    <!-- Mobile burger menu (React island) -->
    <MobileNav
      client:load
      items={navItems}
      ctaLabel={t.book}
      ctaHref="#contacts"
      langLinks={langLinks}
    />
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 lg:h-18"></div>
