---
/**
 * Catch-all route: serves all 210 Tilda-exported pages.
 *
 * Phase 1/2: Tilda HTML via TildaPageLayout.
 * Phase 3: Sanity data injected into HTML at build time (phones, addresses, prices).
 */
import TildaPageLayout from '../layouts/TildaPageLayout.astro';
import { getAllPages, getPageHtml, getRouteSlug } from '../lib/pages';
import { extractSections, removeRecordBlock, extractAndRemoveBlockRange, findRecIdContaining, findNthRecIdAfter } from '../lib/html-extractor';
import { getSiteSettings, getPricingPage } from '../lib/sanity';
import { injectSanityData } from '../lib/sanity-inject';
import { injectPricesData } from '../lib/prices-inject';
import { generateHreflangTags, generateBreadcrumbSchema, generateServiceSchema, generateReviewSchema, generateWebSiteSchema } from '../lib/seo';
import { WHATSAPP_BLOCK, CONTACTS_BLOCK, WHATSAPP_BLOCK_KA, WHATSAPP_BLOCK_EN, CONTACTS_BLOCK_KA, CONTACTS_BLOCK_EN } from '../lib/whatsapp-blocks';
import { getReviewsWidgetHtml } from '../lib/reviews-widget';

const PRICES_SLUGS = new Set(['prices', 'ru/prices', 'en/prices']);

export async function getStaticPaths() {
  const pages = getAllPages();
  const validPages = pages.filter(p => !p.path.includes('.html'));

  // Fetch once for all pages
  const [settings, pricingPage] = await Promise.all([
    getSiteSettings(),
    getPricingPage(),
  ]);

  return validPages.map(page => ({
    params: { slug: getRouteSlug(page) },
    props: { pageFile: page.file, pageTitle: page.title, settings, pricingPage },
  }));
}

interface Props {
  readonly pageFile: string;
  readonly pageTitle: string;
  readonly settings: Awaited<ReturnType<typeof getSiteSettings>>;
  readonly pricingPage: Awaited<ReturnType<typeof getPricingPage>>;
}

const { pageFile, pageTitle, settings, pricingPage } = Astro.props;
const currentSlug = Astro.params.slug ?? '';

const rawHtml = getPageHtml(pageFile);
let injectedHtml = injectSanityData(rawHtml, settings);

if (PRICES_SLUGS.has(currentSlug)) {
  const lang = currentSlug === 'ru/prices' ? 'ru' : currentSlug === 'en/prices' ? 'en' : 'ka';
  injectedHtml = injectPricesData(injectedHtml, pricingPage, lang);
}

const lang = (currentSlug === 'ru' || currentSlug.startsWith('ru/')) ? 'ru'
  : (currentSlug === 'en' || currentSlug.startsWith('en/')) ? 'en'
  : 'ka';
const { headContent, headerBlock, bodyClass, mainContent: rawMainContent } = extractSections(injectedHtml);
let mainContent = rawMainContent;
const reviewsWidgetHtml = getReviewsWidgetHtml(lang);

// SEO: static hreflang, BreadcrumbList, Service, WebSite schemas
const baseSlug = currentSlug.replace(/^(ru|en)\/?/, '');
const seoHead = generateHreflangTags(baseSlug, lang)
  + generateBreadcrumbSchema(baseSlug, lang, pageTitle)
  + generateServiceSchema(baseSlug, lang)
  + (baseSlug === '' ? generateReviewSchema() + generateWebSiteSchema() : '');

if (lang === 'ru') {
  mainContent = removeRecordBlock(mainContent, 'rec1829048981');
  if (!mainContent.includes('rec2091246563')) {
    // Insert before footer (rec603526076), not at the end
    const FOOTER_ID = 'rec603526076';
    const footerIdx = mainContent.indexOf(`id="${FOOTER_ID}"`);
    if (footerIdx >= 0) {
      const divStart = mainContent.lastIndexOf('<div', footerIdx);
      mainContent = mainContent.slice(0, divStart) + WHATSAPP_BLOCK + CONTACTS_BLOCK + mainContent.slice(divStart);
    } else {
      mainContent = mainContent + WHATSAPP_BLOCK + CONTACTS_BLOCK;
    }
  }
  // Move gallery+reviews to just above contacts block
  let galleryReviewsRu = '';
  if (currentSlug === 'ru') {
    [galleryReviewsRu, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec758392198', 'rec1859784471');
  } else if (mainContent.includes('id="rec713423972"')) {
    const galleryStartPos = mainContent.indexOf('id="rec713423972"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      [galleryReviewsRu, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec713423972', reviewsEndId);
    }
  }
  if (galleryReviewsRu) {
    const contactsIdx = mainContent.indexOf('id="rec2091246563"');
    if (contactsIdx >= 0) {
      const divStart = mainContent.lastIndexOf('<div', contactsIdx);
      mainContent = mainContent.slice(0, divStart) + galleryReviewsRu + mainContent.slice(divStart);
    }
  }
}

// Helper: insert block before the first matching footer
function insertBeforeFooter(content: string, block: string, footerIds: readonly string[]): string {
  for (const fid of footerIds) {
    const idx = content.indexOf(`id="${fid}"`);
    if (idx >= 0) {
      const divStart = content.lastIndexOf('<div', idx);
      return content.slice(0, divStart) + block + content.slice(divStart);
    }
  }
  return content + block;
}

if (lang === 'ka') {
  // Remove old contact blocks: desktop, mobile, and map
  mainContent = removeRecordBlock(mainContent, 'rec2091645613');
  mainContent = removeRecordBlock(mainContent, 'rec2091645623');
  mainContent = removeRecordBlock(mainContent, 'rec2091645633');
  if (!mainContent.includes('ba-contacts')) {
    // Extract reviews+gallery from homepage and place just above contacts
    let reviewsGallery = '';
    if (currentSlug === '' || currentSlug === undefined) {
      [reviewsGallery, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec2091645413', 'rec2091645493');
    }
    mainContent = insertBeforeFooter(mainContent, reviewsGallery + CONTACTS_BLOCK_KA, ['rec2091645713', 'rec607481980', 'rec607472568', 'rec603526076']);
  }
  // Subpages: move gallery+reviews above contacts block
  if ((currentSlug !== '' && currentSlug !== undefined) && mainContent.includes('id="rec713418578"')) {
    const galleryStartPos = mainContent.indexOf('id="rec713418578"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      let galleryReviewsKa: string;
      [galleryReviewsKa, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec713418578', reviewsEndId);
      if (galleryReviewsKa) {
        const contactsIdx = mainContent.indexOf('id="rec2091246563"');
        if (contactsIdx >= 0) {
          const divStart = mainContent.lastIndexOf('<div', contactsIdx);
          mainContent = mainContent.slice(0, divStart) + galleryReviewsKa + mainContent.slice(divStart);
        }
      }
    }
  }
  if (!mainContent.includes('ba-wa-wrap')) {
    mainContent = mainContent + WHATSAPP_BLOCK_KA;
  }
}

if (lang === 'en') {
  // Remove old contact blocks: desktop, mobile, and map
  mainContent = removeRecordBlock(mainContent, 'rec1862121201');
  mainContent = removeRecordBlock(mainContent, 'rec1862121211');
  mainContent = removeRecordBlock(mainContent, 'rec1862121221');
  if (!mainContent.includes('ba-contacts')) {
    // Extract gallery+reviews from homepage and place just above contacts
    let galleryEn = '';
    let reviewsEn = '';
    if (currentSlug === 'en') {
      [galleryEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec1862088861', 'rec1862088901');
      [reviewsEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec758753019', 'rec758753021');
    }
    mainContent = insertBeforeFooter(mainContent, galleryEn + reviewsEn + CONTACTS_BLOCK_EN, ['rec607472568', 'rec607473240']);
  }
  // Subpages: move gallery+reviews above contacts block
  if (currentSlug !== 'en' && mainContent.includes('id="rec1862088871"')) {
    const galleryStartPos = mainContent.indexOf('id="rec1862088871"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      let galleryReviewsEn: string;
      [galleryReviewsEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec1862088871', reviewsEndId);
      if (galleryReviewsEn) {
        const contactsIdx = mainContent.indexOf('id="rec2091246563"');
        if (contactsIdx >= 0) {
          const divStart = mainContent.lastIndexOf('<div', contactsIdx);
          mainContent = mainContent.slice(0, divStart) + galleryReviewsEn + mainContent.slice(divStart);
        }
      }
    }
  }
  if (!mainContent.includes('ba-wa-wrap')) {
    mainContent = mainContent + WHATSAPP_BLOCK_EN;
  }
}

// Replace first Elfsight reviews widget with self-hosted widget, remove duplicates
mainContent = mainContent.replace(
  /<div\s+class="elfsight-app-[^"]*"[^>]*>[\s\S]*?<\/div>/,
  reviewsWidgetHtml
);
mainContent = mainContent.replace(
  /<div\s+class="elfsight-app-[^"]*"[^>]*>[\s\S]*?<\/div>/g,
  ''
);
---
<TildaPageLayout
  headContent={headContent}
  seoHead={seoHead}
  headerBlock={headerBlock}
  mainContent={mainContent}
  bodyClass={bodyClass}
  lang={lang}
/>
