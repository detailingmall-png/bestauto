      + mainContent.slice(divStart);
  }
}

// Interior cleaning: fix gallery section heading
if (baseSlug === 'interior-cleaning') {
  const headingReplacements: Record<string, [string, string]> = {
    ru: ['Примеры работ детейлинг мойки салона', 'Примеры работ детейлинг химчистки салона'],
    ka: ['ქიმწმენდის შედეგების მაგალითები', 'ავტომობილის სალონის ქიმწმენდის ნამუშევრების მაგალითები'],
  };
  const pair = headingReplacements[lang];
  if (pair) {
    mainContent = mainContent.replace(pair[0], pair[1]);
  }
}

// PPF page: replace old ba-reels-grid video block with unified video gallery
if (baseSlug === 'ppf-shield-wrapping' && mainContent.includes('ba-reels-grid')) {
  // The reels block sits inside a t-rec div containing 'ba-reels-grid'
  const reelsIdx = mainContent.indexOf('ba-reels-grid');
  const reelsBlockStart = mainContent.lastIndexOf('<div class="r t-rec', reelsIdx);
  if (reelsBlockStart >= 0) {
    // Find the end of this t-rec block (next t-rec sibling or end)
    const nextRecStart = mainContent.indexOf('<div class="r t-rec', reelsBlockStart + 1);
    if (nextRecStart > reelsBlockStart) {
      mainContent = mainContent.slice(0, reelsBlockStart)
        + generateVideoGalleryHtml(lang)
        + mainContent.slice(nextRecStart);
    }
  }
}

// Homepage: inject FAQ accordion before contacts block
if (baseSlug === '' && mainContent.includes('id="rec2091246563"')) {
  const contactsFaqIdx = mainContent.indexOf('id="rec2091246563"');
  const contactsFaqDiv = mainContent.lastIndexOf('<div', contactsFaqIdx);
  if (contactsFaqDiv >= 0) {
    mainContent = mainContent.slice(0, contactsFaqDiv)
      + generateFaqHtml(lang)
      + mainContent.slice(contactsFaqDiv);
  }
}

// === Fix misplaced anchors after all block reordering ===
// Tilda type-215 anchor-only blocks stay in their original positions when
// content blocks are rearranged. Strip all old anchors for affected names
// and re-insert them right before the correct content blocks.

/** Remove every `<a name="...">` for the given anchor name, then insert
 *  a fresh one right before the first `<div` that contains `targetMarker`.
 *  If the target doesn't exist on this page, leave old anchors untouched. */
function relocateAnchor(html: string, name: string, targetMarker: string): string {
  // Only relocate if the target block exists on this page
  if (!html.includes(targetMarker)) return html;
  // Remove all occurrences of this anchor (both inline and inside content)
  let result = html.replace(new RegExp(`<a name="${name}"[^>]*></a>`, 'g'), '');
  // Insert before the target block
  const idx = result.indexOf(targetMarker);
  if (idx >= 0) {
    const divStart = result.lastIndexOf('<div', idx);
    if (divStart >= 0) {
      result = result.slice(0, divStart)
        + `<a name="${name}" style="font-size:0;display:block;" aria-hidden="true"></a>`
        + result.slice(divStart);
    }
  }
  return result;
}

// #contacts → before contacts block (rec2091246563)
mainContent = relocateAnchor(mainContent, 'contacts', 'id="rec2091246563"');

// #reviews → before self-hosted reviews widget
mainContent = relocateAnchor(mainContent, 'reviews', 'id="ba-reviews"');

// #photo → before gallery
mainContent = relocateAnchor(mainContent, 'photo', 'class="ba-gallery"');

// H3: Hide empty named anchors from screen readers
mainContent = mainContent.replace(
  /<a name="([^"]+)"([^>]*)><\/a>/g,
  (match, _name, attrs) => {
    if (attrs.includes('aria-hidden')) return match;
    return `<a name="${_name}"${attrs} aria-hidden="true"></a>`;
  }
);
---
<TildaPageLayout
  headContent={headContent}
  seoHead={seoHead}
  headerBlock={headerBlock}
  mainContent={mainContent}
  bodyClass={bodyClass}
  lang={lang}
/>
