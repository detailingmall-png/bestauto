---
/**
 * Catch-all route: serves all 210 Tilda-exported pages.
 *
 * Phase 1/2: Tilda HTML via TildaPageLayout.
 * Phase 3: Sanity data injected into HTML at build time (phones, addresses, prices).
 */
import TildaPageLayout from '../layouts/TildaPageLayout.astro';
import { getAllPages, getPageHtml, getRouteSlug } from '../lib/pages';
import { extractSections, removeRecordBlock, removeBlockContaining, extractAndRemoveBlockRange, findRecIdContaining, findNthRecIdAfter } from '../lib/html-extractor';
import { getSiteSettings, getPricingPage } from '../lib/sanity';
import { injectSanityData } from '../lib/sanity-inject';
import { injectPricesData } from '../lib/prices-inject';
import { injectServicePrices } from '../lib/service-prices-inject';
import { replaceGalleries } from '../lib/gallery-inject';
import { generateHreflangTags, generateBreadcrumbSchema, generateServiceSchema, generateReviewSchema, generateWebSiteSchema } from '../lib/seo';
import { WHATSAPP_BLOCK, CONTACTS_BLOCK, WHATSAPP_BLOCK_KA, WHATSAPP_BLOCK_EN, CONTACTS_BLOCK_KA, CONTACTS_BLOCK_EN } from '../lib/whatsapp-blocks';
import { generateServicesGridHtml } from '../lib/services-grid';
import { getReviewsWidgetHtml } from '../lib/reviews-widget';

const PRICES_SLUGS = new Set(['prices', 'ru/prices', 'en/prices']);
const SERVICE_SLUGS = new Set([
  'polishing', 'ceramiccoating', 'interior-cleaning', 'interior-restoration',
  'paintless-dent-repair', 'windshield-repair', 'ppf-shield-wrapping', 'vinyl-wrapping',
  'auto-glass-tinting', 'car-soundproofing', 'computer-diagnostics', 'carwash',
]);

// Related-services block rec IDs per "lang/slug" (type-692 blocks, start=end for single block)
const RELATED_BLOCK_RANGES: Readonly<Record<string, readonly [string, string]>> = {
  // KA
  'ka/ceramiccoating':        ['rec611064982', 'rec611064982'],
  'ka/polishing':             ['rec598873537', 'rec598873537'],
  'ka/interior-restoration':  ['rec598889932', 'rec598889932'],
  'ka/interior-cleaning':     ['rec598893339', 'rec598893339'],
  'ka/windshield-repair':     ['rec598893478', 'rec598893478'],
  'ka/ppf-shield-wrapping':   ['rec603096467', 'rec603096467'],
  'ka/vinyl-wrapping':        ['rec604005362', 'rec604005362'],
  'ka/auto-glass-tinting':    ['rec604009889', 'rec604009889'],
  'ka/car-soundproofing':     ['rec604009426', 'rec604009426'],
  'ka/paintless-dent-repair': ['rec604009377', 'rec604009377'],
  'ka/computer-diagnostics':  ['rec614244419', 'rec614244419'],
  // EN
  'en/ceramiccoating':        ['rec603462096', 'rec603462096'],
  'en/polishing':             ['rec597103996', 'rec597103996'],
  'en/interior-restoration':  ['rec603459214', 'rec603459214'],
  'en/interior-cleaning':     ['rec605651300', 'rec605651300'],
  'en/ppf-shield-wrapping':   ['rec600301234', 'rec600301234'],
  'en/windshield-repair':     ['rec598440261', 'rec598440261'],
  'en/vinyl-wrapping':        ['rec603097601', 'rec603097601'],
  'en/paintless-dent-repair': ['rec603498113', 'rec603498113'],
  'en/car-soundproofing':     ['rec603498174', 'rec603498174'],
  'en/auto-glass-tinting':    ['rec603498259', 'rec603498259'],
  'en/computer-diagnostics':  ['rec614236065', 'rec614236065'],
  // RU
  'ru/ceramiccoating':        ['rec595448578', 'rec595448578'],
  'ru/polishing':             ['rec603225450', 'rec603225450'],
  'ru/interior-restoration':  ['rec603225860', 'rec603225860'],
  'ru/interior-cleaning':     ['rec603226140', 'rec603226140'],
  'ru/windshield-repair':     ['rec603226294', 'rec603226294'],
  'ru/auto-glass-tinting':    ['rec603226768', 'rec603226768'],
  'ru/car-soundproofing':     ['rec603226809', 'rec603226809'],
  'ru/paintless-dent-repair': ['rec603227099', 'rec603227099'],
  'ru/vinyl-wrapping':        ['rec603226720', 'rec603226720'],
  'ru/ppf-shield-wrapping':   ['rec603226585', 'rec603226585'],
  'ru/computer-diagnostics':  ['rec610181663', 'rec610181663'],
};

export async function getStaticPaths() {
  const pages = getAllPages();
  const validPages = pages.filter(p => !p.path.includes('.html'));

  // Fetch once for all pages
  const [settings, pricingPage] = await Promise.all([
    getSiteSettings(),
    getPricingPage(),
  ]);

  return validPages.map(page => ({
    params: { slug: getRouteSlug(page) },
    props: { pageFile: page.file, pageTitle: page.title, settings, pricingPage },
  }));
}

interface Props {
  readonly pageFile: string;
  readonly pageTitle: string;
  readonly settings: Awaited<ReturnType<typeof getSiteSettings>>;
  readonly pricingPage: Awaited<ReturnType<typeof getPricingPage>>;
}

const { pageFile, pageTitle, settings, pricingPage } = Astro.props;
const currentSlug = Astro.params.slug ?? '';
const lang = (currentSlug === 'ru' || currentSlug.startsWith('ru/')) ? 'ru'
  : (currentSlug === 'en' || currentSlug.startsWith('en/')) ? 'en'
  : 'ka';
const baseSlug = currentSlug.replace(/^(ru|en)\/?/, '');

const rawHtml = getPageHtml(pageFile);
let injectedHtml = injectSanityData(rawHtml, settings);

if (PRICES_SLUGS.has(currentSlug)) {
  injectedHtml = injectPricesData(injectedHtml, pricingPage, lang);
}

if (SERVICE_SLUGS.has(baseSlug)) {
  injectedHtml = injectServicePrices(injectedHtml, pricingPage, baseSlug, lang);
}

injectedHtml = replaceGalleries(injectedHtml);

// Replace static Tilda services blocks with the new Astro grid (Variant A)
// KA: rec2091645513, RU: rec588623535, EN: rec590463220
const SERVICES_BLOCK_IDS: Readonly<Record<string, string>> = {
  ka: 'rec2091645513',
  ru: 'rec588623535',
  en: 'rec590463220',
};
const servicesBlockId = SERVICES_BLOCK_IDS[lang];
if (servicesBlockId && injectedHtml.includes(`id="${servicesBlockId}"`)) {
  const blockStart = injectedHtml.lastIndexOf('<div', injectedHtml.indexOf(`id="${servicesBlockId}"`));
  if (blockStart >= 0) {
    // Find the closing </div> that matches this block by counting nesting
    let depth = 0;
    let pos = blockStart;
    let blockEnd = -1;
    while (pos < injectedHtml.length) {
      if (injectedHtml.startsWith('<div', pos)) {
        depth++;
        pos += 4;
      } else if (injectedHtml.startsWith('</div>', pos)) {
        depth--;
        if (depth === 0) {
          blockEnd = pos + 6;
          break;
        }
        pos += 6;
      } else {
        pos++;
      }
    }
    if (blockEnd > blockStart) {
      injectedHtml = injectedHtml.slice(0, blockStart) + generateServicesGridHtml(lang) + injectedHtml.slice(blockEnd);
    }
  }
}

const { headContent, headerBlock, bodyClass, mainContent: rawMainContent } = extractSections(injectedHtml);
let mainContent = rawMainContent;
const reviewsWidgetHtml = getReviewsWidgetHtml(lang);

// SEO: static hreflang, BreadcrumbList, Service, WebSite schemas
const seoHead = generateHreflangTags(baseSlug, lang)
  + generateBreadcrumbSchema(baseSlug, lang, pageTitle)
  + generateServiceSchema(baseSlug, lang)
  + (baseSlug === '' ? generateReviewSchema() + generateWebSiteSchema() : '');

if (lang === 'ru') {
  // Extract related-services block and move before footer
  let relatedBlockRu = '';
  const relatedKeyRu = `ru/${baseSlug}`;
  const relatedRangeRu = RELATED_BLOCK_RANGES[relatedKeyRu];
  if (relatedRangeRu) {
    [relatedBlockRu, mainContent] = extractAndRemoveBlockRange(mainContent, relatedRangeRu[0], relatedRangeRu[1]);
  }

  mainContent = removeRecordBlock(mainContent, 'rec1829048981');
  // Remove old contact blocks (unique ID per page — use content-based removal)
  mainContent = removeBlockContaining(mainContent, '550 000 199');
  // Remove "Error get alias" broken Tilda blocks
  mainContent = removeRecordBlock(mainContent, 'rec721622395');
  mainContent = removeRecordBlock(mainContent, 'rec589470557');
  if (!mainContent.includes('rec2091246563')) {
    // Insert before footer (rec603526076), not at the end
    const FOOTER_ID = 'rec603526076';
    const footerIdx = mainContent.indexOf(`id="${FOOTER_ID}"`);
    if (footerIdx >= 0) {
      const divStart = mainContent.lastIndexOf('<div', footerIdx);
      mainContent = mainContent.slice(0, divStart) + WHATSAPP_BLOCK + CONTACTS_BLOCK + mainContent.slice(divStart);
    } else {
      mainContent = mainContent + WHATSAPP_BLOCK + CONTACTS_BLOCK;
    }
  }
  // Move gallery+reviews to just above contacts block
  let galleryReviewsRu = '';
  if (currentSlug === 'ru') {
    [galleryReviewsRu, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec758392198', 'rec2072063053');
  } else if (mainContent.includes('id="rec713423972"')) {
    const galleryStartPos = mainContent.indexOf('id="rec713423972"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      [galleryReviewsRu, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec713423972', reviewsEndId);
    }
  }
  if (galleryReviewsRu) {
    const contactsIdx = mainContent.indexOf('id="rec2091246563"');
    if (contactsIdx >= 0) {
      const divStart = mainContent.lastIndexOf('<div', contactsIdx);
      mainContent = mainContent.slice(0, divStart) + galleryReviewsRu + mainContent.slice(divStart);
    }
  }
  // Insert related-services block after contacts, before footer
  if (relatedBlockRu) {
    mainContent = insertBeforeFooter(mainContent, relatedBlockRu, ['rec603526076']);
  }
}

// Helper: insert block before the first matching footer
function insertBeforeFooter(content: string, block: string, footerIds: readonly string[]): string {
  for (const fid of footerIds) {
    const idx = content.indexOf(`id="${fid}"`);
    if (idx >= 0) {
      const divStart = content.lastIndexOf('<div', idx);
      return content.slice(0, divStart) + block + content.slice(divStart);
    }
  }
  return content + block;
}

if (lang === 'ka') {
  // Extract related-services block and move before footer
  let relatedBlockKa = '';
  const relatedKeyKa = `ka/${baseSlug}`;
  const relatedRangeKa = RELATED_BLOCK_RANGES[relatedKeyKa];
  if (relatedRangeKa) {
    [relatedBlockKa, mainContent] = extractAndRemoveBlockRange(mainContent, relatedRangeKa[0], relatedRangeKa[1]);
  }

  // Remove old contact blocks: homepage IDs + subpage IDs (shared across all KA pages)
  mainContent = removeRecordBlock(mainContent, 'rec2091645613');
  mainContent = removeRecordBlock(mainContent, 'rec2091645623');
  mainContent = removeRecordBlock(mainContent, 'rec2091645633');
  mainContent = removeRecordBlock(mainContent, 'rec1860190671');
  mainContent = removeRecordBlock(mainContent, 'rec1860190681');
  mainContent = removeRecordBlock(mainContent, 'rec1860190701');
  mainContent = removeRecordBlock(mainContent, 'rec1860227531');
  if (!mainContent.includes('ba-contacts')) {
    // Extract reviews+gallery from homepage and place just above contacts
    let reviewsGallery = '';
    if (currentSlug === '' || currentSlug === undefined) {
      [reviewsGallery, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec2091645413', 'rec2091645493');
    }
    mainContent = insertBeforeFooter(mainContent, reviewsGallery + CONTACTS_BLOCK_KA, ['rec2091645713', 'rec607481980', 'rec607472568', 'rec603526076']);
  }
  // Subpages: move gallery+reviews above contacts block
  if ((currentSlug !== '' && currentSlug !== undefined) && mainContent.includes('id="rec713418578"')) {
    const galleryStartPos = mainContent.indexOf('id="rec713418578"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      let galleryReviewsKa: string;
      [galleryReviewsKa, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec713418578', reviewsEndId);
      if (galleryReviewsKa) {
        const contactsIdx = mainContent.indexOf('id="rec2091246563"');
        if (contactsIdx >= 0) {
          const divStart = mainContent.lastIndexOf('<div', contactsIdx);
          mainContent = mainContent.slice(0, divStart) + galleryReviewsKa + mainContent.slice(divStart);
        }
      }
    }
  }
  // Insert related-services block after contacts, before footer
  if (relatedBlockKa) {
    mainContent = insertBeforeFooter(mainContent, relatedBlockKa, ['rec2091645713', 'rec607481980', 'rec607472568', 'rec603526076']);
  }
  if (!mainContent.includes('ba-wa-wrap')) {
    mainContent = mainContent + WHATSAPP_BLOCK_KA;
  }
}

if (lang === 'en') {
  // Extract related-services block and move before footer
  let relatedBlockEn = '';
  const relatedKeyEn = `en/${baseSlug}`;
  const relatedRangeEn = RELATED_BLOCK_RANGES[relatedKeyEn];
  if (relatedRangeEn) {
    [relatedBlockEn, mainContent] = extractAndRemoveBlockRange(mainContent, relatedRangeEn[0], relatedRangeEn[1]);
  }

  // Remove old contact blocks: subpage IDs + service-page CTA/popup IDs
  mainContent = removeRecordBlock(mainContent, 'rec1862121201');
  mainContent = removeRecordBlock(mainContent, 'rec1862121211');
  mainContent = removeRecordBlock(mainContent, 'rec1862121221');
  mainContent = removeRecordBlock(mainContent, 'rec1862088881');
  mainContent = removeRecordBlock(mainContent, 'rec1862088901');
  if (!mainContent.includes('ba-contacts')) {
    // Extract gallery+reviews from homepage and place just above contacts
    let galleryEn = '';
    let reviewsEn = '';
    if (currentSlug === 'en') {
      [galleryEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec1862088861', 'rec2072063803');
      [reviewsEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec758753019', 'rec758753021');
    }
    mainContent = insertBeforeFooter(mainContent, galleryEn + reviewsEn + CONTACTS_BLOCK_EN, ['rec607472568', 'rec607473240']);
  }
  // Subpages: move gallery+reviews above contacts block
  if (currentSlug !== 'en' && mainContent.includes('id="rec1862088871"')) {
    const galleryStartPos = mainContent.indexOf('id="rec1862088871"');
    const reviewsStartId = findRecIdContaining(mainContent, 'name="reviews"', galleryStartPos);
    const reviewsEndId = reviewsStartId ? findNthRecIdAfter(mainContent, reviewsStartId, 2) : null;
    if (reviewsStartId && reviewsEndId) {
      let galleryReviewsEn: string;
      [galleryReviewsEn, mainContent] = extractAndRemoveBlockRange(mainContent, 'rec1862088871', reviewsEndId);
      if (galleryReviewsEn) {
        const contactsIdx = mainContent.indexOf('id="rec2091246563"');
        if (contactsIdx >= 0) {
          const divStart = mainContent.lastIndexOf('<div', contactsIdx);
          mainContent = mainContent.slice(0, divStart) + galleryReviewsEn + mainContent.slice(divStart);
        }
      }
    }
  }
  // Insert related-services block after contacts, before footer
  if (relatedBlockEn) {
    mainContent = insertBeforeFooter(mainContent, relatedBlockEn, ['rec607472568', 'rec607473240']);
  }
  if (!mainContent.includes('ba-wa-wrap')) {
    mainContent = mainContent + WHATSAPP_BLOCK_EN;
  }
}

// Replace first Elfsight reviews widget with self-hosted widget, remove duplicates.
// Elfsight widget divs are always empty (JS populates at runtime), so match only ></div>.
// Using [\s\S]*?<\/div> would risk consuming nested </div> from adjacent HTML.
mainContent = mainContent.replace(
  /<div\s+class="elfsight-app-[^"]*"[^>]*><\/div>/,
  reviewsWidgetHtml
);
mainContent = mainContent.replace(
  /<div\s+class="elfsight-app-[^"]*"[^>]*><\/div>/g,
  ''
);

// Homepage hero: replace background image with video
if (baseSlug === '') {
  const HERO_REC_IDS: Readonly<Record<string, string>> = {
    ka: 'rec2091645383',
    ru: 'rec593575375',
    en: 'rec593573287',
  };
  const heroRecId = HERO_REC_IDS[lang] ?? '';

  const heroVideoHtml = `
<video class="ba-hero-video ba-hero-video--desktop" autoplay muted loop playsinline preload="auto">
  <source src="/hero-desktop.mp4" type="video/mp4">
</video>
<video class="ba-hero-video ba-hero-video--mobile" autoplay muted loop playsinline preload="auto">
  <source src="/hero-mobile.mp4" type="video/mp4">
</video>
<style>
.ba-hero-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 1;
}
.ba-hero-video--mobile { display: none; }
@media screen and (max-width: 639px) {
  .ba-hero-video--desktop { display: none; }
  .ba-hero-video--mobile { display: block; }
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
  document.querySelectorAll('.ba-hero-video').forEach(function(v) {
    if (v.offsetWidth > 0) v.play().catch(function(){});
  });
});
</script>`;

  if (heroRecId && mainContent.includes(`id="${heroRecId}"`)) {
    // Insert video inside the artboard, right before the first .t396__carrier in this block
    const heroIdx = mainContent.indexOf(`id="${heroRecId}"`);
    const carrierIdx = mainContent.indexOf('class="t396__carrier', heroIdx);
    if (carrierIdx >= 0) {
      const carrierDivStart = mainContent.lastIndexOf('<div', carrierIdx);
      mainContent = mainContent.slice(0, carrierDivStart) + heroVideoHtml + mainContent.slice(carrierDivStart);
    }
    // Completely hide the carrier div — prevents Tilda JS from re-applying background on mobile
    mainContent = mainContent.replace(
      new RegExp(`(id="${heroRecId}"[\\s\\S]*?<div class="t396__carrier[^"]*")`),
      '$1 style="display:none!important"'
    );
    // Bump filter z-index above video
    mainContent = mainContent.replace(
      new RegExp(`(#${heroRecId}\\s+\\.t396__filter\\s*\\{)`),
      '$1z-index:2;'
    );
  }
}
---
<TildaPageLayout
  headContent={headContent}
  seoHead={seoHead}
  headerBlock={headerBlock}
  mainContent={mainContent}
  bodyClass={bodyClass}
  lang={lang}
/>
