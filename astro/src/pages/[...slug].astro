---
/**
 * Catch-all route: serves all 210 Tilda-exported pages.
 *
 * Phase 1/2: Tilda HTML via TildaPageLayout.
 * Phase 3: Sanity data injected into HTML at build time (phones, addresses, prices).
 */
import TildaPageLayout from '../layouts/TildaPageLayout.astro';
import { getAllPages, getPageHtml, getRouteSlug } from '../lib/pages';
import { extractSections, removeRecordBlock, removeBlockContaining, removeBlockByRecordType, removeBlocksByScreenClass, translateAltTexts, extractAndRemoveBlockRange, findRecIdContaining, findNthRecIdAfter, stripBlogCtaPlaceholder, stripBlogCmsMetadata, convertBlogInlineFaq, transformT681ToPriceList, extractSectionById, extractDivById, insertAfterBlockByAliasType, insertAfterSectionById, replaceBlogHeroCover } from '../lib/html-extractor';
import { injectHeroVideo } from '../lib/hero-block';
import { generateRelatedServicesHtml } from '../lib/related-services';
import { generateBlogCtaHtml } from '../lib/blog-cta';
import { getSiteSettings, getPricingPage } from '../lib/sanity';
import { injectSanityData } from '../lib/sanity-inject';
import { injectPricesData } from '../lib/prices-inject';
import { injectServicePrices } from '../lib/service-prices-inject';
import { replaceGalleries, removeDuplicateGalleries } from '../lib/gallery-inject';
import { generateHreflangTags, generateBreadcrumbSchema, generateServiceSchema, generateReviewSchema, generateWebSiteSchema, generateServiceFaqSchema, generateArticleSchema, generateOrganizationSchema } from '../lib/seo';
import { WHATSAPP_BLOCK, CONTACTS_BLOCK, WHATSAPP_BLOCK_KA, WHATSAPP_BLOCK_EN, CONTACTS_BLOCK_KA, CONTACTS_BLOCK_EN } from '../lib/whatsapp-blocks';
import { generateServicesGridHtml } from '../lib/services-grid';
import { getReviewsWidgetHtml } from '../lib/reviews-widget';
import { generateBlogGridHtml, DISCONTINUED_BLOG_SLUGS, IMAGE_OVERRIDES } from '../lib/blog-grid';
import { generateBrandLogosHtml } from '../lib/brand-logos';
import { generateProcessStepsHtml } from '../lib/process-steps';
import { generateFaqHtml, generateFaqSchema } from '../lib/faq-section';
import { generateVideoGalleryHtml } from '../lib/video-gallery';
import { replaceTildaFaqSection, removeTildaFaqSchema, renderFaqAccordion, resolveFaqItems } from '../lib/faq-accordion';
import { SERVICE_FAQS } from '../data/service-faqs';

const PRICES_SLUGS = new Set(['prices', 'ru/prices', 'en/prices']);
const SERVICE_SLUGS = new Set([
  'polishing', 'ceramiccoating', 'interior-cleaning',
  'windshield-repair', 'ppf-shield-wrapping', 'vinyl-wrapping',
  'auto-glass-tinting', 'car-soundproofing', 'computer-diagnostics', 'carwash',
]);

export async function getStaticPaths() {
  const discontinuedServiceSlugs = new Set(['paintless-dent-repair', 'interior-restoration']);
  const pages = getAllPages();
  const validPages = pages
    .filter(p => !p.path.includes('.html'))
    .filter(p => !discontinuedServiceSlugs.has(p.slug) && !DISCONTINUED_BLOG_SLUGS.has(p.slug));

  // Fetch once for all pages
  const [settings, pricingPage] = await Promise.all([
    getSiteSettings(),
    getPricingPage(),
  ]);

  return validPages.map(page => ({
    params: { slug: getRouteSlug(page) },
    props: { pageFile: page.file, pageTitle: page.title, settings, pricingPage },
  }));
}

interface Props {
  readonly pageFile: string;
  readonly pageTitle: string;
  readonly settings: Awaited<ReturnType<typeof getSiteSettings>>;
  readonly pricingPage: Awaited<ReturnType<typeof getPricingPage>>;
}

const { pageFile, pageTitle, settings, pricingPage } = Astro.props;
const currentSlug = Astro.params.slug ?? '';
const lang = (currentSlug === 'ru' || currentSlug.startsWith('ru/')) ? 'ru'
  : (currentSlug === 'en' || currentSlug.startsWith('en/')) ? 'en'
  : 'ka';
const baseSlug = currentSlug.replace(/^(ru|en)\/?/, '');

const rawHtml = getPageHtml(pageFile);
let injectedHtml = injectSanityData(rawHtml, settings);

if (PRICES_SLUGS.has(currentSlug)) {
  injectedHtml = injectPricesData(injectedHtml, pricingPage, lang);
  injectedHtml = removeRecordBlock(injectedHtml, 'rec713427892');
  // Fix missing H1: convert hero t001__title <div> to <h1> (KA/RU have a t001 cover block)
  if (injectedHtml.includes('class="t001__title')) {
    injectedHtml = injectedHtml.replace(
      /<div class="t001__title ([^"]*)" field="title">/,
      '<h1 class="t001__title $1" field="title">'
    );
    const h1Start = injectedHtml.indexOf('<h1 class="t001__title');
    if (h1Start >= 0) {
      const closeDiv = injectedHtml.indexOf('</div>', h1Start);
      if (closeDiv >= 0 && closeDiv - h1Start < 500) {
        injectedHtml = injectedHtml.slice(0, closeDiv) + '</h1>' + injectedHtml.slice(closeDiv + 6);
      }
    }
  } else {
    // EN prices: hero is a type-18 rec with an inline-styled <div> title — convert to <h1>
    const heroRe = /(data-record-type="18"[^>]*>\s*)<div (style="[^"]*font-size:\d+[^"]*"[^>]*)>([^<]+)<\/div>/;
    injectedHtml = injectedHtml.replace(heroRe, '$1<h1 $2>$3</h1>');
  }
}

if (SERVICE_SLUGS.has(baseSlug)) {
  injectedHtml = injectServicePrices(injectedHtml, pricingPage, baseSlug, lang);
}

// Carwash: no Sanity pricing section — transform static t681 HTML to ba-price-* layout
if (baseSlug === 'carwash') {
  injectedHtml = transformT681ToPriceList(injectedHtml);
}

injectedHtml = removeDuplicateGalleries(replaceGalleries(injectedHtml));

// Remove studio photo gallery popup buttons and popup slideshows
// (Guramishvili 78 / Anna Politkovskaya 51 toggle buttons + popup photo galleries)
injectedHtml = removeBlockContaining(injectedHtml, 'popup:guramishvili');
injectedHtml = removeBlockContaining(injectedHtml, 'popup:politkovskaya');

// Windshield-repair page: expand H1, hero description, replace PDR with tinting, fix 15→30 cm
if (baseSlug === 'windshield-repair') {
  if (lang === 'ru') {
    injectedHtml = injectedHtml.replaceAll(
      'Ремонт лобового стекла в Тбилиси',
      'Ремонт сколов и трещин, полировка и шлифовка автостекол в Тбилиси'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Мы оказываем услуги по ремонту лобового стекла в Тбилиси. Если на лобовом стекле вашего автомобиля образовался скол или трещина - мы поможем восстановить его. Место ремонта будет едва заметным.',
      'Мы оказываем услуги по ремонту лобового стекла в Тбилиси. Если на стекле вашего автомобиля образовался скол, трещина, царапины или следы от песка - мы поможем восстановить его. Место ремонта будет едва заметным или незаметным вовсе.'
    );
    injectedHtml = injectedHtml.replaceAll(
      'https://bestauto.ge/ru/paintless-dent-repair',
      'https://bestauto.ge/ru/auto-glass-tinting'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Беспокрасочное удаление вмятин',
      'Тонировка стёкол'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Преимущества ремонта сколов и трещин',
      'Преимущества реставрации автостекол'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Цены на ремонт сколов и трещин автостекол',
      'Цены на ремонт сколов и трещин, шлифовку автостекол'
    );
    injectedHtml = injectedHtml.replaceAll('трещины до 15 см', 'трещины до 30 см');
  } else if (lang === 'ka') {
    injectedHtml = injectedHtml.replaceAll(
      'საქარე მინის შეკეთება თბილისში',
      'ავტომინების შეკეთება, პოლირება და შლიფოვკა თბილისში'
    );
    injectedHtml = injectedHtml.replaceAll(
      'საქარე მინაზე ნაკენჭარი ან ბზარი? ვაკეთებთ ადგილზე — შეკეთების შემდეგ კვალი თითქმის უჩინარია. შესამჩნევი იქნება.',
      'მინაზე ნაკენჭარი, ბზარი, ნაკაწრები ან ქვიშის კვალი? დაგეხმარებით აღდგენაში — შეკეთების ადგილი თითქმის უჩინარი ან სრულიად შეუმჩნეველი იქნება.'
    );
    injectedHtml = injectedHtml.replaceAll(
      'https://bestauto.ge/paintless-dent-repair',
      'https://bestauto.ge/auto-glass-tinting'
    );
    injectedHtml = injectedHtml.replaceAll(
      'უფერო ნაკბენის მოცილება',
      'მინების ტონირება'
    );
    injectedHtml = injectedHtml.replaceAll(
      'ჩიპებისა და ბზარების შეკეთების უპირატესობები',
      'ავტომინების რესტავრაციის უპირატესობები'
    );
    injectedHtml = injectedHtml.replaceAll(
      'საქარე მინის ჩიპის და ბზარების შეკეთება',
      'ავტომინის შეკეთება, შლიფოვკა და პოლირება'
    );
    injectedHtml = injectedHtml.replaceAll('ბზარები 15 სმ-მდე', 'ბზარები 30 სმ-მდე');
  } else if (lang === 'en') {
    injectedHtml = injectedHtml.replaceAll(
      'Windshield Repair in Tbilisi',
      'Windshield Repair, Glass Polishing & Grinding in Tbilisi'
    );
    injectedHtml = injectedHtml.replaceAll(
      "We provide glass fixing service in Tbilisi. If your car\u0027s windshield has a chip or crack, we can help restore it. It\u2019ll be barely noticeable.",
      'We provide glass repair services in Tbilisi. If your car\u2019s glass has a chip, crack, scratches or sand marks \u2014 we can help restore it. The repair will be barely noticeable or completely invisible.'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Paintless dent removal',
      'Window tinting'
    );
    injectedHtml = injectedHtml.replaceAll(
      'href="/en/ppf-shield-wrapping"',
      'href="/en/auto-glass-tinting"'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Prices for windshield chip and crack repair',
      'Prices for chip & crack repair, glass grinding'
    );
    injectedHtml = injectedHtml.replaceAll(
      'Advantages of chips and cracks repair',
      'Advantages of auto glass restoration'
    );
    injectedHtml = injectedHtml.replaceAll('cracks up to 15 cm', 'cracks up to 30 cm');
  }
}

// Service pages: replace Tilda t585 accordion with unified native <details>/<summary>
// FAQ component using data from service-faqs.ts
const FAQ_SECTION_TITLE: Readonly<Record<string, string>> = {
  ka: 'ხშირად დასმული კითხვები',
  ru: 'Часто задаваемые вопросы',
  en: 'Frequently Asked Questions',
};
if (SERVICE_SLUGS.has(baseSlug)) {
  const serviceFaqs = SERVICE_FAQS[baseSlug];
  // Always remove Tilda-embedded FAQPage JSON-LD to prevent duplicates with
  // generateServiceFaqSchema() in seoHead (GSC: "Duplicate field FAQPage")
  injectedHtml = removeTildaFaqSchema(injectedHtml);
  if (serviceFaqs && injectedHtml.includes('data-record-type="585"')) {
    const faqItems = resolveFaqItems(serviceFaqs, lang);
    const faqTitle = FAQ_SECTION_TITLE[lang] ?? FAQ_SECTION_TITLE['en'];
    const faqAccordionHtml = renderFaqAccordion(faqItems, faqTitle, {
      id: `${baseSlug}-faq`,
      paddingY: 75,
    });
    injectedHtml = replaceTildaFaqSection(injectedHtml, faqAccordionHtml);
  }
}

// Replace static Tilda services blocks with the new Astro grid (Variant A)
// KA: rec2091645513, RU: rec588623535, EN: rec590463220
const SERVICES_BLOCK_IDS: Readonly<Record<string, string>> = {
  ka: 'rec2091645513',
  ru: 'rec588623535',
  en: 'rec590463220',
};
const servicesBlockId = SERVICES_BLOCK_IDS[lang];
if (servicesBlockId && injectedHtml.includes(`id="${servicesBlockId}"`)) {
  const blockStart = injectedHtml.lastIndexOf('<div', injectedHtml.indexOf(`id="${servicesBlockId}"`));
  if (blockStart >= 0) {
    // Find the closing </div> that matches this block by counting nesting
    let depth = 0;
    let pos = blockStart;
    let blockEnd = -1;
    while (pos < injectedHtml.length) {
      if (injectedHtml.startsWith('<div', pos)) {
        depth++;
        pos += 4;
      } else if (injectedHtml.startsWith('</div>', pos)) {
        depth--;
        if (depth === 0) {
          blockEnd = pos + 6;
          break;
        }
        pos += 6;
      } else {
        pos++;
      }
    }
    if (blockEnd > blockStart) {
      injectedHtml = injectedHtml.slice(0, blockStart) + generateServicesGridHtml(lang) + injectedHtml.slice(blockEnd);
    }
  }
}

// Homepage: inject process steps section after services grid
if (baseSlug === '' && injectedHtml.includes('id="ba-services-grid"')) {
  const gridEndMarker = 'id="ba-services-grid"';
  const gridIdx = injectedHtml.indexOf(gridEndMarker);
  // Find closing </div> of the services grid wrapper
  let depth = 0;
  let pos = injectedHtml.lastIndexOf('<div', gridIdx);
  let gridEnd = -1;
  while (pos < injectedHtml.length) {
    if (injectedHtml.startsWith('<div', pos)) { depth++; pos += 4; }
    else if (injectedHtml.startsWith('</div>', pos)) {
      depth--;
      if (depth === 0) { gridEnd = pos + 6; break; }
      pos += 6;
    } else { pos++; }
  }
  if (gridEnd > 0) {
    injectedHtml = injectedHtml.slice(0, gridEnd) + generateProcessStepsHtml(lang) + injectedHtml.slice(gridEnd);
  }
}

// Homepage: inject brand logos strip between hero and About section
if (baseSlug === '') {
  const ABOUT_ANCHOR_IDS: Readonly<Record<string, string>> = {
    ka: 'rec2091645393',
    ru: 'rec588593929',
    en: 'rec1862088841',
  };
  const aboutId = ABOUT_ANCHOR_IDS[lang];
  if (aboutId && injectedHtml.includes(`id="${aboutId}"`)) {
    const aboutIdx = injectedHtml.indexOf(`id="${aboutId}"`);
    const aboutDivStart = injectedHtml.lastIndexOf('<div', aboutIdx);
    if (aboutDivStart >= 0) {
      injectedHtml = injectedHtml.slice(0, aboutDivStart)
        + generateBrandLogosHtml(lang)
        + injectedHtml.slice(aboutDivStart);
    }
  }
}

// Blog index pages: replace static t404 card grid with dynamic one
const BLOG_INDEX_T404_IDS: Readonly<Record<string, string>> = {
  ka: 'rec607481069',
  ru: 'rec603531262',
  en: 'rec604491219',
};
if (baseSlug === 'blog') {
  // Fix missing H1: KA and EN blog index pages use <div class="t225__title"> instead of <h1>
  if (lang !== 'ru') {
    injectedHtml = injectedHtml.replace(
      /<div class="t225__title t-title t-title_md" field="title">/,
      '<h1 class="t225__title t-title t-title_md" field="title">'
    );
    // Close the matching tag (find the </div> right after the title text)
    const t225H1Start = injectedHtml.indexOf('<h1 class="t225__title');
    if (t225H1Start >= 0) {
      const closeDivAfter = injectedHtml.indexOf('</div>', t225H1Start);
      if (closeDivAfter >= 0) {
        injectedHtml = injectedHtml.slice(0, closeDivAfter) + '</h1>' + injectedHtml.slice(closeDivAfter + 6);
      }
    }
  }
  const t404Id = BLOG_INDEX_T404_IDS[lang];
  if (t404Id && injectedHtml.includes(`id="${t404Id}"`)) {
    const blockStart = injectedHtml.lastIndexOf('<div', injectedHtml.indexOf(`id="${t404Id}"`));
    if (blockStart >= 0) {
      let depth = 0;
      let pos = blockStart;
      let blockEnd = -1;
      while (pos < injectedHtml.length) {
        if (injectedHtml.startsWith('<div', pos)) { depth++; pos += 4; }
        else if (injectedHtml.startsWith('</div>', pos)) {
          depth--;
          if (depth === 0) { blockEnd = pos + 6; break; }
          pos += 6;
        } else { pos++; }
      }
      if (blockEnd > blockStart) {
        injectedHtml = injectedHtml.slice(0, blockStart)
          + generateBlogGridHtml(lang)
          + injectedHtml.slice(blockEnd);
      }
    }
  }
}

const { headContent, headerBlock: rawHeader, bodyClass, mainContent: rawMainContent } = extractSections(injectedHtml, lang, baseSlug, baseSlug === '');
let mainContent = removeBlockContaining(rawMainContent, 't-map-lazyload');

// CTA copy improvements: nav button
const CTA_NAV: Readonly<Record<string, readonly [string, string]>> = {
  ru: ['Записаться', 'Бесплатная консультация'],
  ka: ['დაჯავშნეთ ვიზიტი', 'უფასო კონსულტაცია'],
  en: ['Book a visit', 'Free consultation'],
};
let headerBlock = rawHeader;
const navCta = CTA_NAV[lang];
if (navCta) {
  headerBlock = headerBlock.replaceAll(
    `t-btnflex__text">${navCta[0]}</span>`,
    `t-btnflex__text">${navCta[1]}</span>`
  );
}

// Homepage hero: inject video into original Tilda Zero Block (no tilda-zero.js dependency)
if (baseSlug === '') {
  mainContent = injectHeroVideo(mainContent, lang);
}
const reviewsWidgetHtml = getReviewsWidgetHtml(lang);

// Blog pages: rewrite bare #anchor links in nav to point to homepage
// (sections like #about, #photo, #reviews only exist on the homepage)
const isBlogPage = baseSlug === 'blog' || baseSlug.startsWith('blog/');
if (isBlogPage) {
  const homePath = lang === 'ka' ? '/' : `/${lang}/`;
  mainContent = mainContent.replace(
    /href="#((?!contacts\b)[^"]+)"/g,
    `href="${homePath}#$1"`
  );
}

// Blog articles: strip broken CTA placeholder, CMS metadata, and convert inline FAQ to accordion
if (isBlogPage && baseSlug !== 'blog') {
  mainContent = stripBlogCtaPlaceholder(mainContent);
  mainContent = stripBlogCmsMetadata(mainContent);
  mainContent = convertBlogInlineFaq(mainContent, lang);

  // Replace duplicate hero cover images with unique Pexels photos
  const heroOverride = IMAGE_OVERRIDES[baseSlug];
  if (heroOverride) {
    mainContent = replaceBlogHeroCover(mainContent, baseSlug, heroOverride);
  }

  // Blog audit text corrections (build-time transforms)
  if (lang === 'ru') {
    mainContent = mainContent.replaceAll('\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430 \u043e\u0442 \u0442\u043e\u043d\u0438\u0440\u043e\u0432\u043a\u0438', '\u041f\u0440\u0435\u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u0430 \u0442\u043e\u043d\u0438\u0440\u043e\u0432\u043a\u0438');
    mainContent = mainContent.replaceAll('\u043a\u0430\u043c\u0435\u043d\u044c\u0438\u0441\u043f\u043e\u0440\u0442\u0438\u0442', '\u043a\u0430\u043c\u0435\u043d\u044c \u0438\u0441\u043f\u043e\u0440\u0442\u0438\u0442');
    mainContent = mainContent.replaceAll('Gyeon Q2 Bailiwick', 'Gyeon Q\u00b2 One');
    mainContent = mainContent.replaceAll('\u041d\u043e\u0432\u044b\u0435 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u044f', '\u041d\u043e\u0432\u044b\u0435 \u0430\u0432\u0442\u043e\u043c\u043e\u0431\u0438\u043b\u0438');
    // Blog RU audit — content fixes (2026-04-04)
    mainContent = mainContent.replaceAll('плёнка сохраняет 15-25% стоимости при перепродаже', 'плёнка помогает лучше сохранить внешний вид и ликвидность при перепродаже');
    mainContent = mainContent.replaceAll('при перепродаже стоит на 15-30% дороже', 'при перепродаже обычно выглядит привлекательнее для покупателя');
    mainContent = mainContent.replaceAll('Реальный срок в Грузии 1–3 года', 'В реальных условиях Грузии срок службы чаще 2–5 лет — в зависимости от состава и ухода');
    mainContent = mainContent.replaceAll('Короткий ответ: да, нужна.', 'Чаще всего — да, если есть микродефекты или голограммы. На новом идеальном ЛКП иногда достаточно лёгкой подготовки.');
    mainContent = mainContent.replaceAll('идеальная стратегия', 'рациональная стратегия');
  }
  if (lang === 'ka') {
    mainContent = mainContent.replaceAll('\u10de\u10dd\u10da\u10d8\u10e0\u10dd\u10d1\u10d0', '\u10de\u10dd\u10da\u10d8\u10e0\u10d4\u10d1\u10d0');
    mainContent = mainContent.replaceAll('\u10d2\u10d6\u10d0\u10db\u10d9\u10d5\u10da\u10d4\u10d5\u10d8\u10d8', '\u10d2\u10d6\u10d0\u10db\u10d9\u10d5\u10da\u10d4\u10d5\u10d8');
    mainContent = mainContent.replaceAll('\u10e1\u10d0\u10ec\u10d8\u10dc\u10d0\u10d0\u10e6\u10db\u10d3\u10d4\u10d2\u10dd \u10de\u10e3\u10da\u10de\u10d8\u10e1 \u10e4\u10d8\u10e0\u10d8', '\u10d3\u10d0\u10db\u10ea\u10d0\u10d5\u10d8 \u10e4\u10d8\u10e0\u10d8');
    mainContent = mainContent.replaceAll('\u10d9\u10d4\u10e0\u10d0\u10db\u10d8\u10d9\u10e3\u10da\u10d8 \u10da\u10d8\u10dc\u10d6\u10d4\u10d1\u10d8', '\u10db\u10d8\u10dc\u10d4\u10d1\u10d8\u10e1 \u10d9\u10d4\u10e0\u10d0\u10db\u10d8\u10d9\u10e3\u10da\u10d8 \u10e1\u10d0\u10e4\u10d0\u10e0\u10d8');
    mainContent = mainContent.replaceAll('\u10e5\u10d5\u10d4\u10d3\u10d0 \u10e1\u10d0\u10e0\u10d4\u10ea\u10ee\u10d8', '\u10eb\u10e0\u10d0\u10d5\u10d8\u10e1 \u10d2\u10d0\u10dc\u10e7\u10dd\u10e4\u10d8\u10da\u10d4\u10d1\u10d8\u10e1 \u10ec\u10db\u10d4\u10dc\u10d3\u10d0');
    // Blog KA audit — terminology fixes (2026-04-04)
