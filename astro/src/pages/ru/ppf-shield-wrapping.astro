---
/**
 * PILOT PAGE: /ru/ppf-shield-wrapping/
 * New component-based page replacing Tilda export.
 * Content is hardcoded for the pilot — will migrate to Sanity CMS after approval.
 */

import BaseLayout from '../../components/layout/BaseLayout.astro';
import Head from '../../components/seo/Head.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import WhatsAppWidget from '../../components/layout/WhatsAppWidget.astro';
import HeroImage from '../../components/blocks/HeroImage.astro';
import FeatureNumbered from '../../components/blocks/FeatureNumbered.astro';
import ProcessSteps from '../../components/blocks/ProcessSteps.astro';
import PricingTable from '../../components/blocks/PricingTable.astro';
import BrandLogos from '../../components/blocks/BrandLogos.astro';
import FaqAccordion from '../../components/blocks/FaqAccordion.astro';
import ContactForm from '../../components/blocks/ContactForm.astro';
import RelatedServices from '../../components/blocks/RelatedServices.astro';
import ReviewsCarousel from '../../components/blocks/ReviewsCarousel.astro';
import Breadcrumbs from '../../components/blocks/Breadcrumbs.astro';
import { getSiteSettings } from '../../lib/sanity';
import reviewsData from '../../data/reviews.json';

const settings = await getSiteSettings();
const studios = settings?.studios ?? [];

// ── Reviews data ──
const reviewsForDisplay = reviewsData.reviews
  .filter((r: any) => r.rating >= 4)
  .slice(0, 15)
  .map((r: any) => ({
    authorName: r.authorName,
    authorPhotoUrl: r.authorPhotoUrl,
    rating: r.rating,
    relativeTime: r.relativeTimes?.ru ?? r.relativeTime,
    text: r.texts?.ru ?? r.text,
  }));

// ── Content (will move to Sanity CMS) ──

const benefits = [
  {
    title: 'Защита от повреждений',
    description: 'Плёнка поглощает удары и царапины, создавая барьер от сколов, ультрафиолета и химических воздействий.',
  },
  {
    title: 'Улучшение внешнего вида',
    description: 'PPF увеличивает блеск кузова до 40%, придавая глянцевый эффект.',
  },
  {
    title: 'Долговечность до 10 лет',
    description: 'Пленка PPF имеет длительный срок службы и защищает кузов на срок до 10 лет.',
  },
  {
    title: 'Самоисцеляющиеся свойства',
    description: 'Мелкие царапины исчезают самостоятельно под воздействием тепла или солнечного света.',
  },
  {
    title: 'Прозрачность и незаметность на кузове',
    description: 'Полностью прозрачна — не искажает цвет кузова и абсолютно незаметна.',
  },
];

const brands = [
  {
    name: 'LLumar',
    description: 'Американский бренд с 60-летней историей. Превосходная прозрачность и самоисцеление.',
  },
  {
    name: 'Quantum',
    description: 'Высокоэластичная плёнка нового поколения с усиленной защитой от сколов.',
  },
  {
    name: 'LuxArmor',
    description: 'Премиум-класс с матовыми и глянцевыми вариантами. Максимальная толщина защиты.',
  },
];

const pricing = [
  { name: 'Оклейка автомобиля полностью', price: 'от 7500', isPromo: true },
  { name: 'Оклейка капота, переднего бампера, передних крыльев, стоек', price: 'от 2500' },
  { name: 'Оклейка капота', price: 'от 800' },
  { name: 'Оклейка бампера', price: 'от 900' },
  { name: 'Оклейка передних фар', price: 'от 350' },
  { name: 'Оклейка панорамной крыши', price: 'от 950' },
  { name: 'Оклейка лобового стекла', price: 'от 1100' },
];

const processSteps = [
  { title: 'Консультация', description: 'Осматриваем автомобиль, подбираем плёнку и зоны оклейки' },
  { title: 'Подготовка кузова', description: 'Мойка, деконтаминация и полировка при необходимости' },
  { title: 'Оклейка PPF', description: 'Профессиональная установка в чистой студии — от 1 до 5 дней' },
  { title: 'Контроль качества', description: 'Проверяем каждый элемент на отсутствие дефектов' },
  { title: 'Выдача с гарантией', description: 'Приёмка вместе с вами — гарантийный сертификат на руки' },
];

const trustItems = [
  { title: '5 лет опыта в детейлинге', description: 'Профессиональная оклейка сотен автомобилей разных марок и моделей' },
  { title: '2 студии в Тбилиси', description: 'Гурамишвили 78 и Анна Политковская 51 — выберите удобную локацию' },
  { title: '10 лет гарантии на плёнку', description: 'Покрываем отслаивание, пожелтение и дефекты материала' },
  { title: '2000 довольных клиентов', description: 'Сотни отзывов, рейтинг 4.9★ на Google.' },
];

const faqItems = [
  { question: 'А у вас точно оригинальная плёнка?', answer: 'Да, мы работаем только с сертифицированными дистрибьюторами LLumar, Quantum и LuxArmor. При приёмке выдаём сертификат подлинности материала.' },
  { question: 'Есть ли гарантия на работу?', answer: 'На PPF плёнку — до 10 лет гарантии от пожелтения и отслаивания. При приёмке выдаём гарантийный сертификат.' },
  { question: 'Сколько времени занимает оклейка?', answer: 'Полная оклейка PPF обычно занимает 3–5 рабочих дней, частичная (капот, фары, бампер) — 1–2 дня.' },
  { question: 'На сколько хватает плёнки PPF?', answer: 'Срок службы качественной PPF плёнки — от 5 до 10 лет при правильном уходе.' },
  { question: 'Нужно ли мыть машину перед приездом?', answer: 'Нет, мы проводим полную подготовку: мойка, деконтаминация и при необходимости полировка включены в стоимость.' },
  { question: 'Будет ли плёнка заметна на кузове?', answer: 'Качественная PPF плёнка практически невидима. Она обладает высокой прозрачностью и не искажает цвет автомобиля.' },
  { question: 'Как ухаживать за плёнкой после оклейки?', answer: 'Первые 48 часов не мыть. Затем — ручная мойка pH-нейтральными средствами. Автоматическая мойка не рекомендуется.' },
  { question: 'Можно ли пленку PPF удалить со временем?', answer: 'Да, плёнку можно удалить без повреждения лака при профессиональном снятии.' },
];

const relatedServices = [
  { name: 'Полировка кузова', href: '/ru/polishing/' },
  { name: 'Керамическое покрытие', href: '/ru/ceramiccoating/' },
  { name: 'Удаление вмятин без покраски', href: '/ru/paintless-dent-repair/' },
  { name: 'Ремонт лобового стекла', href: '/ru/windshield-repair/' },
];
---

<BaseLayout lang="ru">
  <Head
    slot="head"
    title="Оклейка авто пленкой PPF в Тбилиси — цены | BESTAUTO"
    description="Оклейка автомобилей защитной полиуретановой плёнкой PPF в Тбилиси. Защита от царапин, сколов и ультрафиолета. 10 лет гарантии. Цены от 2500 GEL."
    lang="ru"
    slug="ru/ppf-shield-wrapping"
    baseSlug="ppf-shield-wrapping"
    isService={true}
    includeReviews={true}
  />

  <Header slot="header" lang="ru" baseSlug="ppf-shield-wrapping" />

  {/* Breadcrumbs */}
  <Breadcrumbs items={[
    { label: 'Главная', href: '/ru/' },
    { label: 'Услуги', href: '/ru/' },
    { label: 'Оклейка PPF' },
  ]} />

  {/* 1. Hero */}
  <HeroImage
    title="Оклейка авто пленкой PPF в Тбилиси"
    subtitle="Гарантия 10 лет · Пленки LLumar, Quantum, LuxArmor · Более 2000 оклеенных авто"
    ctaText="Записаться на бесплатный осмотр"
    ctaHref="#contacts"
    bgImage="/images/tild6437-3762-4563-a430-663034316636__depositphotos_444297.webp"
  />

  {/* 2. Преимущества (checkmarks) */}
  <FeatureNumbered
    sectionTitle="Преимущества оклейки PPF пленкой автомобиля"
    items={benefits}
  />

  {/* 3. Бренды */}
  <BrandLogos
    sectionTitle="Какие плёнки мы используем"
    subtitle="Подберём оптимальный вариант под ваш бюджет и задачи"
    brands={brands}
  />

  {/* 4. Цены */}
  <PricingTable
    sectionTitle="Цены на оклейку авто плёнкой PPF в Тбилиси"
    subtitle="Точная цена зависит от марки и модели автомобиля"
    items={pricing}
    ctaText="Рассчитать стоимость для вашего авто"
    ctaHref="#contacts"
  />

  {/* 5. Процесс */}
  <ProcessSteps
    sectionTitle="Как проходит оклейка в BESTAUTO"
    steps={processSteps}
  />

  {/* 6. Почему мы (numbered trust points) */}
  <section class="section-spacing">
    <div class="container-ba">
      <div class="text-center mb-3 lg:mb-4">
        <h2 class="text-5xl lg:text-7xl font-bold text-white-primary text-balance">Почему стоит выбрать нашу компанию?</h2>
        <p class="text-md lg:text-xl text-gray-400 mt-2">Вы точно останетесь довольны</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 max-w-5xl mx-auto">
        {trustItems.map((item, index) => (
          <div data-reveal={String(Math.min(index, 5))} class="flex items-start gap-2">
            <div class="shrink-0 w-6 h-6 rounded-full bg-gold-accent flex items-center justify-center mt-0.5">
              <span class="text-sm font-bold text-black-primary">{index + 1}</span>
            </div>
            <div>
              <h3 class="text-xl lg:text-2xl font-semibold text-white-primary mb-0.5">{item.title}</h3>
              {item.description && (
                <p class="text-base text-gray-400 leading-relaxed">{item.description}</p>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 7. FAQ */}
  <FaqAccordion
    sectionTitle="Часто задаваемые вопросы"
    items={faqItems}
    ctaText="Остались вопросы? Напишите нам"
    ctaHref="#contacts"
  />

  {/* 8. Отзывы */}
  <ReviewsCarousel
    sectionTitle="Реальные отзывы наших клиентов"
    overallRating={reviewsData.overallRating}
    totalReviews={reviewsData.totalReviews}
    reviews={reviewsForDisplay}
    mapsUrl="https://maps.app.goo.gl/6RCqDZGKNdmVdRZ58"
    lang="ru"
  />

  {/* 9. Контакты */}
  <ContactForm
    lang="ru"
    studios={studios}
    sectionTitle="Выберите <em>ближайшую</em> студию"
  />

  {/* 10. Связанные услуги */}
  <RelatedServices
    sectionTitle="Вместе с оклейкой заказывают"
    services={relatedServices}
    lang="ru"
  />

  <Footer slot="footer" lang="ru" />

  <WhatsAppWidget phone="+995550000299" lang="ru" />
</BaseLayout>
