---
/**
 * TildaPageLayout: wraps every migrated Tilda page.
 *
 * Receives pre-extracted sections (head, header, body) and assembles
 * a complete HTML document. This is the single source of truth for
 * page structure — Phase 3 will feed Sanity content through this layout.
 */

interface Props {
  /** Raw <head> content (page-specific CSS, JS, meta tags) */
  headContent: string;
  /** Static SEO tags: hreflang, BreadcrumbList, Service, WebSite schemas */
  seoHead?: string;
  /** The <!--header--> analytics block from the Tilda shared header */
  headerBlock: string;
  /** Main page content (nav + all blocks + footer) */
  mainContent: string;
  /** Body element class (usually "t-body") */
  bodyClass?: string;
  /** BCP-47 language tag for <html lang="..."> */
  lang?: string;
}

import { readFileSync } from 'node:fs';
import { join } from 'node:path';

const CUSTOM_CSS = readFileSync(join(process.cwd(), 'public/css/bestauto-custom.css'), 'utf8');

const {
  headContent,
  seoHead = '',
  headerBlock,
  mainContent,
  bodyClass = 't-body',
  lang = 'ka',
} = Astro.props;

const STICKY_CTA_TEXT: Record<string, string> = {
  ru: 'Записаться на бесплатный осмотр',
  en: 'Book a Free Inspection',
  ka: 'ჩაეწერეთ უფასო დათვალიერებაზე',
};
---
<!DOCTYPE html>
<html lang={lang}>
<head>
<link rel="icon" href="/images/tild3835-3238-4533-b837-373331316562__favicon_1.ico" type="image/x-icon">
<Fragment set:html={headContent} />
<style set:html={CUSTOM_CSS} />
<Fragment set:html={seoHead} />
</head>
<body class={bodyClass} style="margin:0;">
<!--allrecords-->
<div
  id="allrecords"
  data-tilda-export="yes"
  class="t-records"
  data-hook="blocks-collection-content-node"
  data-tilda-project-id="6825691"
  data-tilda-project-country="GE"
>
  <Fragment set:html={headerBlock} />
  <Fragment set:html={mainContent} />
</div>
<!--/allrecords-->
<div class="ba-sticky-cta" aria-label="CTA"><a class="ba-sticky-cta__link" href="#contacts">{STICKY_CTA_TEXT[lang] ?? STICKY_CTA_TEXT.ka}</a></div>
<script>
(function(){var b=document.querySelector('.ba-sticky-cta');if(!b||window.innerWidth>640)return;var t=window.innerHeight;var on=false;function c(){var s=window.scrollY>=t;if(s!==on){on=s;if(s)b.classList.add('is-visible');else b.classList.remove('is-visible')}}window.addEventListener('scroll',c,{passive:true});c()})();
</script>
<script src="/js/tracking.js?v=9" defer></script>
<script>(function(){var ric=window.requestIdleCallback||function(f){return setTimeout(f,5000)};ric(function(){var s=document.createElement('script');s.src='/js/webmcp.js?v=1';s.async=true;document.head.appendChild(s)},{timeout:5000})})();</script>
</body>
</html>
