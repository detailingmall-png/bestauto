---
/**
 * TildaPageLayout: wraps every migrated Tilda page.
 *
 * Receives pre-extracted sections (head, header, body) and assembles
 * a complete HTML document. This is the single source of truth for
 * page structure — Phase 3 will feed Sanity content through this layout.
 */

interface Props {
  /** Raw <head> content (page-specific CSS, JS, meta tags) */
  headContent: string;
  /** Static SEO tags: hreflang, BreadcrumbList, Service, WebSite schemas */
  seoHead?: string;
  /** The <!--header--> analytics block from the Tilda shared header */
  headerBlock: string;
  /** Main page content (nav + all blocks + footer) */
  mainContent: string;
  /** Body element class (usually "t-body") */
  bodyClass?: string;
  /** BCP-47 language tag for <html lang="..."> */
  lang?: string;
}

const {
  headContent,
  seoHead = '',
  headerBlock,
  mainContent,
  bodyClass = 't-body',
  lang = 'ka',
} = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
<Fragment set:html={headContent} />
<Fragment set:html={seoHead} />
</head>
<body class={bodyClass} style="margin:0;">
<!--allrecords-->
<div
  id="allrecords"
  data-tilda-export="yes"
  class="t-records"
  data-hook="blocks-collection-content-node"
  data-tilda-project-id="6825691"
  data-tilda-project-country="GE"
>
  <Fragment set:html={headerBlock} />
  <Fragment set:html={mainContent} />
</div>
<!--/allrecords-->
</body>
</html>
